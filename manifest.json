{
  "manifest_version": 3,
  "name": "Koetomo Volume",
  "version": "1.2",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://koetomo.fun/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://koetomo.fun/*"],
      "js": ["content.js"]
    }
  ]
}